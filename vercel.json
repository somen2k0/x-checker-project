{
  "buildCommand": "pnpm --filter @workspace/x-checker run build",
  "outputDirectory": "artifacts/x-checker/dist/public",
  "installCommand": "pnpm install",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
