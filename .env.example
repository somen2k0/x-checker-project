# ─────────────────────────────────────────────────────────────────────────────
# X Toolkit — Environment Variables
#
# HOW TO USE:
#   Local dev  → copy this file to .env and fill in real values
#   Production → add each variable in Vercel dashboard:
#                Settings → Environment Variables → Add New
#
# NEVER commit .env to version control.
# .env is already listed in .gitignore — keep it that way.
# ─────────────────────────────────────────────────────────────────────────────


# ══════════════════════════════════════════════════════════════════════════════
# BACKEND — only readable by the Express server (never sent to the browser)
# ══════════════════════════════════════════════════════════════════════════════

# [REQUIRED] Twitter/X bearer token used to authenticate all account-check
# requests. Obtain via https://developer.twitter.com, or use X's own public
# app token (search "Twitter public bearer token" — it is publicly documented).
TWITTER_BEARER_TOKEN=

# [OPTIONAL] Groq API key for AI-powered features: bio generator, AI detector.
# Without this key those tools return 503 Service Unavailable.
# Get a free key at: https://console.groq.com
GROQ_API_KEY=

# [OPTIONAL] RapidAPI keys for additional tools (comma-separated).
# The server rotates through them automatically if one hits a rate limit.
# Add multiple keys separated by commas: key1,key2,key3
# Get keys at: https://rapidapi.com
RAPIDAPI_KEYS=

# [OPTIONAL] Admin panel password. Leave empty to disable the admin panel.
# Access the panel at /api/admin using the header: x-admin-password: <value>
ADMIN_PASSWORD=

# [OPTIONAL] Web3Forms access key for the server-side contact form endpoint.
# Without this the /api/contact route returns 503.
# Get a free key at: https://web3forms.com
WEB3FORMS_KEY=


# ══════════════════════════════════════════════════════════════════════════════
# FRONTEND — embedded at Vite build time, visible in the browser bundle
#
# ⚠️  VITE_ variables are PUBLIC. Never put secret keys in VITE_ variables.
#     Only use VITE_ for keys that are safe to expose (e.g. public access keys,
#     analytics IDs, feature flags). Real API secrets go in the backend section
#     above and are never prefixed with VITE_.
# ══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL] Web3Forms access key for the in-app feedback modal.
# Web3Forms keys are designed to be used in the browser — exposing this
# via VITE_ is safe and intentional.
# Get a free key at: https://web3forms.com (same key as WEB3FORMS_KEY is fine)
VITE_WEB3FORMS_KEY=
