# ─────────────────────────────────────────────────────────────────────────────
# X Account Checker — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── API Server (backend) ─────────────────────────────────────────────────────

# X / Twitter bearer token used to authenticate requests to the Twitter API.
# The app ships with X's own public bearer token as a fallback, but you can
# override it here with your own token from developer.twitter.com.
TWITTER_BEARER_TOKEN=

# Groq API key for AI-powered features (bio generator, AI detector).
# Get your key at: https://console.groq.com
GROQ_API_KEY=

# RapidAPI keys for additional tools (comma-separated for key rotation).
# Get keys at: https://rapidapi.com
RAPIDAPI_KEYS=

# Admin panel password. Leave empty to disable the admin panel entirely.
ADMIN_PASSWORD=

# ── Frontend (Vite / client-side) ────────────────────────────────────────────
# Variables prefixed with VITE_ are embedded at build time and visible in
# the browser bundle. Only put non-sensitive public keys here.

# Web3Forms access key for the feedback/contact form.
# Get your key at: https://web3forms.com (free tier available)
VITE_WEB3FORMS_KEY=
