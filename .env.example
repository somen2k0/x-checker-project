# ─── X Toolkit — Environment Variables ────────────────────────────────────────
# Copy this file to .env.local for local development.
# On Vercel, set these in Project Settings → Environment Variables.

# ── Replit dev-only (set automatically on Replit, not needed on Vercel) ────────
# PORT=5173
# BASE_PATH=/

# ── Optional: X / Twitter bearer token ────────────────────────────────────────
# The app uses a public fallback bearer token by default.
# Set your own token from developer.twitter.com to avoid rate limits.
# TWITTER_BEARER_TOKEN=

# ── Google Analytics 4 ────────────────────────────────────────────────────────
# Replace the placeholder in src/lib/analytics.ts with your real GA4 ID.
# You can also expose it as an env var if you prefer:
# VITE_GA_ID=G-XXXXXXXXXX

# ── Google AdSense ────────────────────────────────────────────────────────────
# Replace ca-pub-XXXXXXXXXXXXXXXXX in index.html with your real publisher ID.
# Only add the script once your site is approved by AdSense.
